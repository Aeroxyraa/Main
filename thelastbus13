-- ==========================================
-- AUTO RUN + ANIMASI + SHORTCUT R
-- ==========================================
local autoSprintConn = nil
local runAnimTrack = nil

local function setupRunAnimation(hum)
    if runAnimTrack then runAnimTrack:Stop() end
    local animator = hum:FindFirstChild("Animator") or Instance.new("Animator", hum)
   
    local anim = Instance.new("Animation")
    anim.AnimationId = "rbxassetid://83307380732694"
   
    runAnimTrack = animator:LoadAnimation(anim)
    runAnimTrack.Priority = Enum.AnimationPriority.Action4
    runAnimTrack.Looped = true
end

local function toggleAutoRun(enabled)
    if enabled then
        autoSprintConn = runService.RenderStepped:Connect(function()
            local char = localPlayer.Character
            if not char then return end
            local hum = char:FindFirstChild("Humanoid")
            if not hum then return end
           
            hum.WalkSpeed = 24
           
            if hum.MoveDirection.Magnitude > 0.1 then
                if not runAnimTrack or not runAnimTrack.IsPlaying then
                    setupRunAnimation(hum)
                    runAnimTrack:Play()
                end
            else
                if runAnimTrack and runAnimTrack.IsPlaying then
                    runAnimTrack:Stop()
                end
            end
        end)
    else
        if autoSprintConn then
            autoSprintConn:Disconnect()
            autoSprintConn = nil
        end
        if runAnimTrack then
            runAnimTrack:Stop()
            runAnimTrack = nil
        end
       
        local char = localPlayer.Character
        if char then
            local hum = char:FindFirstChild("Humanoid")
            if hum then hum.WalkSpeed = 10 end
        end
    end
end

local function updateAutoRunButton(enabled)
    for _, f in ipairs(scroll:GetChildren()) do
        if f:IsA("Frame") then
            local label = f:FindFirstChildWhichIsA("TextLabel")
            local btn = f:FindFirstChildWhichIsA("TextButton")
            if label and btn and label.Text:find("Auto Run") then
                btn.BackgroundColor3 = enabled and Color3.fromRGB(40, 140, 40) or Color3.fromRGB(150, 40, 40)
                btn.Text = enabled and "ON" or "OFF"
                break
            end
        end
    end
end

