local function applyGhostESP(ghost)
    if not toggles.Ghost then return end
    local color = ghostColors[ghost.Name]
    if not color or activeGhostESPs[ghost] then return end
    local orig = ghost:FindFirstChild("GhostESP")
    if orig then orig.Enabled = false end
    local hl = Instance.new("Highlight")
    hl.Name = "BodyChams"
    hl.FillColor = color
    hl.FillTransparency = 0.5
    hl.OutlineColor = Color3.new(1, 1, 1)
    hl.Parent = ghost
    local ghostRoot = ghost:FindFirstChild("HumanoidRootPart") or ghost:FindFirstChildWhichIsA("BasePart")
    local label = nil
    if ghostRoot then
        local bboard = Instance.new("BillboardGui")
        bboard.Name = "DistanceESP"
        bboard.Size = UDim2.new(0, 120, 0, 25)
        bboard.StudsOffset = Vector3.new(0, 4, 0)
        bboard.AlwaysOnTop = true
        bboard.Adornee = ghostRoot
        bboard.Parent = ghost
        label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, 0, 1, 0)
        label.BackgroundTransparency = 1
        label.TextColor3 = color
        label.TextSize = 13
        label.Font = Enum.Font.SourceSansBold
        label.TextStrokeTransparency = 0.3
        label.TextStrokeColor3 = Color3.new(0,0,0)
        label.Text = ghost.Name
        label.Parent = bboard
    end
    activeGhostESPs[ghost] = {Chams = hl, Label = label, Root = ghostRoot, Name = ghost.Name}
end

local function removeGhostESP(ghost)
    if activeGhostESPs[ghost] then
        if activeGhostESPs[ghost].Chams then activeGhostESPs[ghost].Chams:Destroy() end
        local bboard = ghost:FindFirstChild("DistanceESP")
        if bboard then bboard:Destroy() end
        local orig = ghost:FindFirstChild("GhostESP")
        if orig then orig.Enabled = true end
        activeGhostESPs[ghost] = nil
    end
end

local function applyPlayerESP(player)
    if player == localPlayer or activePlayerESPs[player] then return end
    local function handleCharacter(char)
        if not toggles.Player then return end
        task.wait(0.5)
        if char and char.Parent then
            local hl = Instance.new("Highlight")
            hl.Name = "PlayerChams"
            hl.FillColor = Color3.fromRGB(255, 255, 255)
            hl.FillTransparency = 0.6
            hl.OutlineColor = Color3.fromRGB(255, 255, 255)
            hl.Parent = char
            activePlayerESPs[player] = hl
        end
    end
    player.CharacterAdded:Connect(handleCharacter)
    if player.Character then handleCharacter(player.Character) end
end

local function removePlayerESP(player)
    if activePlayerESPs[player] then activePlayerESPs[player]:Destroy() activePlayerESPs[player] = nil end
end

local function addItemESP(object, displayName, color)
    if not object:IsA("BasePart") and not object:IsA("Model") then return end
    local part = object:IsA("Model") and (object.PrimaryPart or object:FindFirstChildWhichIsA("BasePart")) or object
    if not part or activeItemESPs[object] then return end
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "ItemESP_" .. displayName
    billboard.AlwaysOnTop = true
    billboard.Size = UDim2.new(0, 100, 0, 25)
    billboard.StudsOffset = Vector3.new(0, 1.5, 0)
    billboard.Adornee = part
    billboard.Parent = part
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.TextColor3 = color
    label.TextSize = 12
    label.Font = Enum.Font.SourceSansBold
    label.TextStrokeTransparency = 0.3
    label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    label.Text = displayName
    label.Parent = billboard
    activeItemESPs[object] = {Gui = billboard, Label = label, Part = part, NameTag = displayName, MainColor = color}
end

local function removeItemESP(object)
    if activeItemESPs[object] then
        if activeItemESPs[object].Gui then activeItemESPs[object].Gui:Destroy() end
        activeItemESPs[object] = nil
    end
end

local function refreshItemESPState(toggleName, folderName, displayName, color)
    local targetFolder = workspace:FindFirstChild(folderName)
    if not toggles[toggleName] then
        for obj, data in pairs(activeItemESPs) do
            if data.NameTag == displayName then removeItemESP(obj) end
        end
        return
    end
    if targetFolder then
        for _, child in ipairs(targetFolder:GetChildren()) do
            if child.Name:lower():find(displayName:lower()) or folderName:lower():find("spawn") or folderName:lower():find("lamps") then
                addItemESP(child, displayName, color)
            end
        end
    end
end

