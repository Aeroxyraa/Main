local function createRowToggle(name, toggleKey, folderTarget, dispName, color, orderID)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 32)
    frame.BackgroundTransparency = 1
    frame.LayoutOrder = orderID
    frame.Parent = scroll

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0, 200, 1, 0)
    label.Text = " " .. name
    label.TextColor3 = Color3.fromRGB(220, 220, 220)
    label.TextSize = 13
    label.Font = Enum.Font.SourceSans
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.BackgroundTransparency = 1
    label.Parent = frame

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 75, 0, 24)
    btn.Position = UDim2.new(1, -80, 0, 4)
    btn.BackgroundColor3 = Color3.fromRGB(150, 40, 40)
    btn.Text = "OFF"
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextSize = 11
    btn.Font = Enum.Font.SourceSansBold
    btn.BorderSizePixel = 0
    btn.Parent = frame
   
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 4)
    corner.Parent = btn

    btn.MouseButton1Click:Connect(function()
        toggles[toggleKey] = not toggles[toggleKey]
        btn.BackgroundColor3 = toggles[toggleKey] and Color3.fromRGB(40, 140, 40) or Color3.fromRGB(150, 40, 40)
        btn.Text = toggles[toggleKey] and "ON" or "OFF"
       
        if toggleKey == "AutoRun" then
            toggleAutoRun(toggles[toggleKey])
        elseif toggleKey == "Ghost" then
            if toggles.Ghost and enemiesFolder then
                for _, ghost in ipairs(enemiesFolder:GetChildren()) do applyGhostESP(ghost) end
            else
                if enemiesFolder then for _, ghost in ipairs(enemiesFolder:GetChildren()) do removeGhostESP(ghost) end end
            end
        elseif toggleKey == "Player" then
            if toggles.Player then
                for _, p in ipairs(players:GetPlayers()) do applyPlayerESP(p) end
            else
                for _, p in ipairs(players:GetPlayers()) do removePlayerESP(p) end
            end
        elseif toggleKey ~= "InstantPrompt" and toggleKey ~= "NoClip" then
            refreshItemESPState(toggleKey, folderTarget, dispName, color)
        end
    end)
end

