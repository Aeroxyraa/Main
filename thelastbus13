-- Global Render Loop
runService.RenderStepped:Connect(function()
    local myChar = localPlayer.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end
    if toggles.Ghost then
        for ghost, data in pairs(activeGhostESPs) do
            if data.Root and ghost.Parent then
                local dist = (myRoot.Position - data.Root.Position).Magnitude / 2.8
                if data.Label then data.Label.Text = string.format("%s [%.1f m]", data.Name, dist) end
            else removeGhostESP(ghost) end
        end
    end
    for object, data in pairs(activeItemESPs) do
        if data.Part and data.Part.Parent and object.Parent then
            local distance = (myRoot.Position - data.Part.Position).Magnitude / 2.8
            data.Label.Text = string.format("✨ %s [%.1f M]", data.NameTag, distance)
        else removeItemESP(object) end
    end
end)

